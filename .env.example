# ──────────────────────────────────────────────────────────────
# Queue Cure — Environment Variables
# Copy to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Find both in: Dashboard → Settings → API

# Project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon key — used by browser (patient screen, auth)
# RLS restricts this to SELECT-only after migration 002
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used by server-side API routes ONLY
# Bypasses RLS for INSERT/UPDATE/DELETE — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Clinic ────────────────────────────────────────────────────
# After running migration 001, copy the UUID from its output:
#   SELECT id FROM clinics WHERE slug = 'default';
#
# NEXT_PUBLIC_ prefix required so WaitingRoom.tsx (client component)
# can also use it to scope the patients query. The UUID is not secret.
NEXT_PUBLIC_CLINIC_ID=your-clinic-uuid-here

# ── AI Triage ─────────────────────────────────────────────────
# Groq API key — free at: https://console.groq.com/keys
# Used for LLaMA 3.1 8B Instant triage classification
GROQ_API_KEY=gsk_your-groq-key-here

# ── Staff Access (optional — demo mode allows any email if unset) ─
# STAFF_ALLOWED_EMAILS=reception@clinic.com,admin@clinic.com
# STAFF_EMAIL_DOMAINS=clinic.com

# ── Clinic timezone for queue "today" boundaries (IANA name) ───
# CLINIC_TIMEZONE=Asia/Kolkata
